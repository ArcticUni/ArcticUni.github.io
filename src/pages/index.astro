---
import "../styles/global.css";
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import productCan from "../assets/images/product-can.png";
import productCapsule from "../assets/images/product-capsule.png";
import productShell from "../assets/images/product-shell.png";
import heroBg from "../assets/images/hero-bg.jpg";
import formatIngredient from "../assets/images/format-ingredient.png";
import formatCapsule from "../assets/images/format-capsule.png";
import formatCan from "../assets/images/format-can.png";

const trustItems = [
  "EuroFins Third-Party Tested",
  "MFDS Compliant",
  "Full Batch Traceability",
  "Sustainably Harvested",
  "Heavy Metals Verified",
];

const highlights = [
  {
    label: "Sourcing",
    title: "Arctic Origin",
    text: "Harvested from the pristine waters at 69°N, where Arctic currents create one of the purest marine ecosystems on Earth.",
  },
  {
    label: "Environment",
    title: "Sustainable Harvest",
    text: "Responsible harvesting that protects marine biodiversity, ensuring the Arctic ecosystem thrives for generations to come.",
  },
  {
    label: "Partnership",
    title: "Marine Spark X",
    text: "A Marine Spark X initiative combining marine science expertise with premium supplement formulation.",
  },
];

const specs = [
  ["Calcium (marine-derived)", "250 mg per capsule"],
  ["Source", "Arctic sea urchin shell"],
  ["Trace minerals", "Mg, K, Zn, Sr, P"],
  ["Standard dose", "1 capsule / day"],
  ["Enhanced dose", "3 capsules / day (750 mg)"],
  ["Capsules per tin", "60"],
  ["Shelf life", "36 months"],
];

const scienceCards = [
  {
    badge: "Third-Party Tested",
    title: "EuroFins Laboratory Testing",
    text: "Every batch is independently tested by EuroFins, a globally recognised laboratory network, ensuring our product meets the highest standards of purity and potency.",
  },
  {
    badge: "Korean Market Ready",
    title: "MFDS Compliance",
    text: "Formulated in full alignment with South Korea's Ministry of Food and Drug Safety standards. Documentation available for immediate regulatory submission.",
  },
  {
    badge: "Full Chain of Custody",
    title: "Batch Traceability",
    text: "Every tin can be traced back to a specific harvest location and processing date. Ocean to capsule, documented.",
  },
  {
    badge: "Certificate of Analysis",
    title: "Heavy Metals Verified",
    text: "Comprehensive COA for every batch including lead, mercury, cadmium, and arsenic. All results well below regulatory limits.",
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="ArcticUNI — Premium marine calcium sourced from Arctic sea urchins at 69°N. Pure. Traceable. Third-party verified."
    />
    <meta property="og:title" content="ArcticUNI — Arctic Marine Calcium" />
    <meta
      property="og:description"
      content="The world's most sustainable calcium. Sourced from Arctic sea urchins at 69°N."
    />
    <meta property="og:url" content="https://arcticuni.github.io" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>ArcticUNI — Arctic Marine Calcium</title>
  </head>

  <body class="bg-white text-navy font-body antialiased">

    <!-- NAV -->
    <nav
      class="fixed top-0 left-0 right-0 z-50 bg-white/95 border-b border-mist backdrop-blur-sm"
      id="nav"
    >
      <div
        class="max-w-7xl mx-auto px-6 py-5 flex items-center justify-between transition-all duration-300"
        id="nav-inner"
      >
        <a
          href="/"
          class="font-display text-2xl font-semibold text-navy tracking-wide"
          >ArcticUNI</a
        >
        <div
          class="hidden md:flex items-center gap-10 text-sm tracking-[0.12em] uppercase font-medium"
        >
          <a href="#origin" class="text-navy-mid hover:text-navy transition-colors">Origin</a>
          <a href="#product" class="text-navy-mid hover:text-navy transition-colors">Product</a>
          <a href="#science" class="text-navy-mid hover:text-navy transition-colors">Science</a>
          <a
            href="#contact"
            class="px-5 py-2.5 border border-navy text-navy hover:bg-navy hover:text-white transition-all"
            >Enquire</a
          >
        </div>
        <button
          id="menu-toggle"
          class="md:hidden text-navy p-2"
          aria-label="Toggle menu"
        >
          <Icon name="lucide:menu" class="w-6 h-6" />
        </button>
      </div>
      <div
        id="mobile-menu"
        class="hidden md:hidden bg-white border-t border-mist"
      >
        <div
          class="px-6 py-6 flex flex-col gap-1 text-sm tracking-[0.12em] uppercase font-medium"
        >
          <a href="#origin" class="text-navy-mid hover:text-navy transition-colors py-3 border-b border-mist">Origin</a>
          <a href="#product" class="text-navy-mid hover:text-navy transition-colors py-3 border-b border-mist">Product</a>
          <a href="#science" class="text-navy-mid hover:text-navy transition-colors py-3 border-b border-mist">Science</a>
          <a href="#contact" class="text-navy-mid hover:text-navy transition-colors py-3">Enquire</a>
        </div>
      </div>
    </nav>

    <!-- HERO -->
    <section class="relative min-h-screen flex items-center overflow-hidden">
      <Image
        src={heroBg}
        alt=""
        class="absolute inset-0 w-full h-full object-cover object-center"
        widths={[768, 1024, 1440, 1920]}
      />
      <div class="absolute inset-0 bg-navy/25"></div>
      <div
        class="relative w-full max-w-7xl mx-auto px-6 pt-24 pb-16 grid md:grid-cols-2 gap-12 md:gap-20 items-center"
      >
        <div>
          <p
            class="text-sm tracking-[0.25em] uppercase text-gold font-medium mb-6 animate-fade-up"
            style="animation-delay: 0.1s"
          >
            69°N · Arctic Norway · Marine Calcium
          </p>
          <h1
            class="font-display text-6xl md:text-7xl lg:text-8xl font-light text-white leading-[1.05] mb-8 animate-fade-up"
            style="animation-delay: 0.3s"
          >
            The World's Most<br /><em>Sustainable<br />Calcium.</em>
          </h1>
          <p
            class="text-base leading-relaxed text-white/75 max-w-md mb-10 animate-fade-up"
            style="animation-delay: 0.5s"
          >
            Sourced from Arctic sea urchins at 69°N. Pure. Traceable.
            Third-party verified for the world's most demanding markets.
          </p>
          <div
            class="flex items-center gap-6 flex-wrap animate-fade-up"
            style="animation-delay: 0.7s"
          >
            <a
              href="#product"
              class="inline-block px-9 py-4 bg-white text-navy text-sm tracking-[0.12em] uppercase font-medium hover:bg-ice transition-colors"
            >
              Discover the Product
            </a>
            <a
              href="#science"
              class="text-sm tracking-[0.1em] uppercase text-white/60 border-b border-white/20 pb-px hover:text-white hover:border-white/50 transition-all"
            >
              Quality &amp; Science →
            </a>
          </div>
        </div>

        <div
          class="flex items-center justify-start animate-fade-up"
          style="animation-delay: 0.4s"
        >
          <Image
            src={productCan}
            alt="ArcticUNI Premium Marine Calcium supplement tin"
            class="w-72 md:w-96 lg:w-[28rem] h-auto drop-shadow-2xl"
            widths={[384, 512, 640]}
          />
        </div>
      </div>
    </section>

    <!-- TRUST BAR -->
    <div class="bg-ice border-y border-mist py-6 px-6">
      <div
        class="max-w-7xl mx-auto flex flex-wrap items-center justify-center gap-x-12 gap-y-3"
      >
        {
          trustItems.map((item) => (
            <div class="flex items-center gap-2.5 text-sm tracking-[0.1em] uppercase text-navy-mid font-medium">
              <span class="w-2 h-2 rounded-full bg-gold shrink-0" />
              {item}
            </div>
          ))
        }
      </div>
    </div>

    <!-- PRODUCT FORMATS -->
    <section class="py-20 md:py-28 px-6 bg-ice">
      <div class="max-w-7xl mx-auto">
        <p class="text-sm tracking-[0.25em] uppercase text-gold font-medium mb-14 text-center">
          Available Formats
        </p>
        <div class="grid grid-cols-3 gap-6 md:gap-16 items-end">
          <div class="flex flex-col items-center gap-8 reveal">
            <Image
              src={formatIngredient}
              alt="ArcticUNI marine calcium ingredient"
              class="w-full max-w-[20rem] md:max-w-[26rem] h-auto"
              widths={[320, 416, 512]}
            />
            <div class="text-center">
              <p class="font-display text-2xl md:text-3xl text-navy font-light">ArcticUNI<sup class="text-sm">TM</sup></p>
              <p class="text-sm tracking-[0.12em] uppercase text-navy-mid font-medium mt-2">Ingredient</p>
            </div>
          </div>
          <div class="flex flex-col items-center gap-8 reveal" style="transition-delay: 0.1s">
            <Image
              src={formatCapsule}
              alt="ArcticUNI calcium capsule bulk format"
              class="w-full max-w-[90rem] md:max-w-[110rem] h-auto"
              widths={[480, 768, 1024]}
            />
            <div class="text-center">
              <p class="font-display text-2xl md:text-3xl text-navy font-light">ArcticUNI<sup class="text-sm">TM</sup></p>
              <p class="text-sm tracking-[0.12em] uppercase text-navy-mid font-medium mt-2">Bulk</p>
            </div>
          </div>
          <div class="flex flex-col items-center gap-8 reveal" style="transition-delay: 0.2s">
            <Image
              src={formatCan}
              alt="ArcticUNI finished supplement tin"
              class="w-full max-w-[12rem] md:max-w-[15rem] h-auto"
              widths={[192, 240, 320]}
            />
            <div class="text-center">
              <p class="font-display text-2xl md:text-3xl text-navy font-light">ArcticUNI<sup class="text-sm">TM</sup></p>
              <p class="text-sm tracking-[0.12em] uppercase text-navy-mid font-medium mt-2">White Label</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ORIGIN -->
    <section id="origin" class="py-20 md:py-28 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="grid md:grid-cols-2 gap-16 md:gap-24 items-center">
          <div class="reveal">
            <p class="text-sm tracking-[0.25em] uppercase text-gold font-medium mb-5">
              Origin
            </p>
            <h2
              class="font-display text-5xl md:text-6xl font-light text-navy leading-tight mb-7"
            >
              Born from the<br />Arctic Ocean.
            </h2>
            <p class="text-base leading-relaxed text-navy-mid mb-5">
              ArcticUNI is derived from sustainably harvested sea urchins in
              the crystal-clear waters of Northern Norway — one of the cleanest
              marine environments on Earth. Every batch is fully traceable from
              ocean to capsule.
            </p>
            <p class="text-base leading-relaxed text-navy-mid">
              A partnership between Marine Spark X and leading marine research
              institutions, united by a shared vision: bringing the purest
              marine calcium in the world to premium markets.
            </p>
          </div>

          <div
            class="flex flex-col items-center justify-center p-14 md:p-20 bg-ice border border-mist reveal"
            style="transition-delay: 0.15s"
          >
            <span
              class="font-display text-8xl md:text-9xl font-light text-navy leading-none"
              >69°N</span
            >
            <span class="text-sm tracking-[0.2em] uppercase text-silver-dark mt-4"
              >Arctic Norway</span
            >
            <p
              class="text-sm text-center text-navy-mid leading-relaxed mt-4 max-w-48"
            >
              Tromsø · Where pristine Arctic currents create one of Earth's
              purest marine ecosystems.
            </p>
          </div>
        </div>

        <div class="grid md:grid-cols-3 gap-10 mt-20">
          {
            highlights.map((h, i) => (
              <div
                class="border-t-2 border-mist pt-7 reveal"
                style={`transition-delay: ${i * 0.1}s`}
              >
                <p class="text-sm tracking-[0.2em] uppercase text-gold font-medium mb-3">
                  {h.label}
                </p>
                <h3 class="font-display text-2xl text-navy mb-3 font-normal">
                  {h.title}
                </h3>
                <p class="text-sm leading-relaxed text-navy-mid">{h.text}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- PRODUCT -->
    <section id="product" class="py-20 md:py-28 px-6 bg-ice">
      <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-16 md:gap-24 items-center">
        <div class="flex items-center justify-center reveal">
          <Image
            src={productCan}
            alt="ArcticUNI finished product tin"
            class="w-full max-w-[28rem] md:max-w-[36rem] h-auto drop-shadow-2xl"
            widths={[448, 576, 720]}
          />
        </div>

        <div class="reveal" style="transition-delay: 0.15s">
          <p class="text-sm tracking-[0.25em] uppercase text-gold font-medium mb-5">
            The Product
          </p>
          <h2
            class="font-display text-5xl md:text-6xl font-light text-navy leading-tight mb-5"
          >
            From Sea<br />to Supplement.
          </h2>
          <p class="text-base leading-relaxed text-navy-mid mb-10">
            250 mg of marine calcium per capsule, naturally rich in trace
            minerals. No additives. No shortcuts. 60 capsules per tin,
            36-month shelf life.
          </p>

          <table class="w-full">
            {
              specs.map(([label, value]) => (
                <tr class="border-b border-mist">
                  <td class="py-4 text-navy-mid text-sm">{label}</td>
                  <td class="py-4 text-navy font-medium text-sm text-right">
                    {value}
                  </td>
                </tr>
              ))
            }
          </table>
        </div>
      </div>
    </section>

    <!-- SCIENCE -->
    <section id="science" class="py-20 md:py-28 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="mb-16 reveal">
          <p class="text-sm tracking-[0.25em] uppercase text-gold font-medium mb-5">
            Quality &amp; Science
          </p>
          <h2
            class="font-display text-5xl md:text-6xl font-light text-navy leading-tight"
          >
            Verified Purity.<br />Proven Quality.
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-px bg-mist">
          {
            scienceCards.map((card, i) => (
              <div
                class="bg-white p-10 md:p-14 hover:bg-ice transition-colors duration-300 reveal"
                style={`transition-delay: ${i * 0.1}s`}
              >
                <span class="inline-block text-sm tracking-[0.15em] uppercase border border-gold text-gold px-3 py-1.5 mb-6">
                  {card.badge}
                </span>
                <h3 class="font-display text-2xl text-navy mb-4 font-normal">
                  {card.title}
                </h3>
                <p class="text-sm leading-relaxed text-navy-mid">{card.text}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- CONTACT -->
    <section id="contact" class="py-20 md:py-28 px-6 bg-navy">
      <div class="max-w-2xl mx-auto text-center reveal">
        <p class="text-sm tracking-[0.25em] uppercase text-silver font-medium mb-5">
          Get in Touch
        </p>
        <h2
          class="font-display text-5xl md:text-6xl font-light text-white leading-tight mb-7"
        >
          Partner with Us.
        </h2>
        <p class="text-base leading-relaxed text-white/50 mb-12">
          Interested in distribution, partnership, or learning more about
          ArcticUNI? We'd love to hear from you.
        </p>
        <a
          href="mailto:Gustav@marinesparkx.com"
          class="font-display text-3xl text-silver hover:text-white transition-colors border-b border-silver/30 pb-px"
        >
          Gustav@marinesparkx.com
        </a>
        <p class="text-sm text-white/25 mt-12 tracking-wide">
          Framstredet 10 · Tromsø, Norway · 69°N
        </p>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="bg-navy border-t border-white/5 py-8 px-6">
      <div
        class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4"
      >
        <span class="font-display text-xl text-white/40">ArcticUNI</span>
        <a
          href="https://marinesparkx.github.io"
          class="text-sm text-white/25 hover:text-white/50 transition-colors tracking-wide"
        >
          A Marine Spark X Partnership ↗
        </a>
        <span class="text-sm text-white/20 tracking-wide">© 2026 ArcticUNI</span>
      </div>
    </footer>

    <script>
      const nav = document.getElementById("nav") as HTMLElement;
      const navInner = document.getElementById("nav-inner") as HTMLElement;

      window.addEventListener("scroll", () => {
        if (window.scrollY > 50) {
          navInner.style.paddingTop = "0.6rem";
          navInner.style.paddingBottom = "0.6rem";
        } else {
          navInner.style.paddingTop = "";
          navInner.style.paddingBottom = "";
        }
      });

      const toggle = document.getElementById("menu-toggle");
      const menu = document.getElementById("mobile-menu");
      toggle?.addEventListener("click", () => {
        menu?.classList.toggle("hidden");
      });
      menu?.querySelectorAll("a").forEach((a) =>
        a.addEventListener("click", () => menu?.classList.add("hidden")),
      );

      const reveals = document.querySelectorAll(".reveal");
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("revealed");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: "0px 0px -50px 0px" },
      );
      reveals.forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
